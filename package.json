{
  "name": "war-archive-front",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web",
    "mobile"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @war-archive/web",
    "dev:mobile": "npm run start --workspace @war-archive/mobile",
    "build": "npm run build --workspace @war-archive/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
